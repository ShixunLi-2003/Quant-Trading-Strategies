{
  "project_config": "../project.json",
  "name": "hk_w42_bear_defense_recommended",
  "engine": "vectorbt",
  "universe": {
    "mode": "scan_all"
  },
  "date_range": {
    "start": "2018-01-01",
    "end": "2026-05-09"
  },
  "fields": ["open", "high", "close", "volume", "amount"],
  "factor_list": [
    {
      "name": "W-42",
      "ascending": false,
      "params": null,
      "weight": 20
    },
    {
      "name": "returns_momentum",
      "ascending": false,
      "params": {
        "window": 21
      },
      "weight": 0.6
    },
    {
      "name": "price_vs_ma",
      "ascending": false,
      "params": {
        "window": 20
      },
      "weight": 0.6
    },
    {
      "name": "trend_compression_score",
      "ascending": false,
      "params": {
        "positive_window": 9,
        "short_window": 1,
        "min_short_return": -0.02,
        "max_short_return": 0.01
      },
      "weight": 0.1
    },
    {
      "name": "avg_amount_level",
      "ascending": false,
      "params": {
        "window": 3,
        "log_transform": true
      },
      "weight": 0.35
    },
    {
      "name": "bbi_upturn_score",
      "ascending": false,
      "params": {
        "windows": [5, 10, 12, 21],
        "slope_window": 1,
        "normalize_by_close": true
      },
      "weight": 0.16
    },
    {
      "name": "obv_bottom_rising_score",
      "ascending": false,
      "params": {
        "lookback": 12,
        "slope_window": 4,
        "smooth_window": 2
      },
      "weight": 0.04
    }
  ],
  "universe_filter": {
    "min_close": 0.8,
    "min_amount": 0.0
  },
  "signal": {
    "name": "top_n_hold",
    "params": {
      "top_n": 5,
      "rebalance_every_n_days": 15,
      "ascending": true
    }
  },
  "regime_risk_control": {
    "enabled": true,
    "benchmark_ma_window": 120,
    "bull_top_n": 5,
    "bear_top_n": 5,
    "bull_exposure": 1.0,
    "bear_exposure": 0.9,
